<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ultra Matrix - Install</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="install-page">
  <div class="install-card">
    <div style="font-size: 48px; margin-bottom: 16px;">⚡</div>
    <h1>Ultra Matrix</h1>
    <p>Bulk import &amp; export content to your Shopify store.<br>Agent-ready API for automation.</p>
    <form action="/auth" method="GET">
      <div class="form-group">
        <label>Your Shopify Store URL</label>
        <input type="text" name="shop" class="form-control" placeholder="yourstore.myshopify.com" required
          style="text-align: center;">
      </div>
      <button type="submit" class="btn btn-primary btn-lg" style="width: 100%;">
        Install App
      </button>
    </form>
    <p style="margin-top: 24px; font-size: 12px; color: var(--text-muted);">
      By installing, you authorize Ultra Matrix to access your store data.
    </p>
  </div>
</div>
</body>
</html>
