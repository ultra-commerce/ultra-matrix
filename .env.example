# Shopify App Credentials (from Shopify Partners dashboard)
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_SCOPES=read_content,write_content,read_themes,write_themes,read_products,write_products,read_customers,write_customers,read_orders,write_orders

# App URL (Shopify CLI sets HOST automatically in dev mode)
HOST=https://ultra-matrix-production.up.railway.app
PORT=3000

# PostgreSQL Database (Railway provides this automatically)
DATABASE_URL="postgresql://user:password@host:5432/ultra_matrix?schema=public"

# Redis — Railway provides REDIS_URL automatically
# Use REDIS_URL for Railway, or individual vars for local dev
REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Agent API Key (for Claude Cowork / OpenClaw access)
ULTRA_MATRIX_API_KEY=um_your_secret_api_key_here

# Environment
NODE_ENV=development
LOG_LEVEL=info
