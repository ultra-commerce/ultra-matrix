{
  "name": "ultra-matrix",
  "version": "2.0.0",
  "private": true,
  "description": "Ultra Matrix - Shopify bulk import/export SaaS app (Matrixify alternative)",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "setup": "npm install && npx prisma generate && echo 'Setup complete! Run: npm run dev'",
    "db:migrate": "npx prisma migrate deploy",
    "db:push": "npx prisma db push",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bullmq": "^5.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.5.1",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-fileupload": "^1.5.1",
    "ioredis": "^5.4.0",
    "uuid": "^10.0.0",
    "winston": "^3.14.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "prisma": "^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
